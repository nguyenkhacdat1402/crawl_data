doctype html
html(lang='vi')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title So sánh sản phẩm - FPT Shop
    link(rel='stylesheet', href='https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css')
    link(rel='stylesheet', href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css')
    link(rel="stylesheet", href="/client/css/style.css")
  body
    .store-header.fpt-header
      .container
        a(href='/').back-link
          i.fas.fa-arrow-left.mr-2
          | Quay lại so sánh 2 cửa hàng
        h1.text-center FPT Shop
        p.text-center.mb-0 So sánh sản phẩm FPT Shop

    .container
      .row
        .col-md-6
          .store-card
            h2.store-title.fpt-title FPT Shop - Sản phẩm 1
            .form-group
              label(for='fpt-product-1') Chọn sản phẩm:
              select#fpt-product-1.product-select
                option(value='', disabled, selected) -- Chọn sản phẩm --
                each item in productsFpt
                  option(value=item.id, data-id=item.id) #{item.name}

        .col-md-6
          .store-card
            h2.store-title.fpt-title FPT Shop - Sản phẩm 2
            .form-group
              label(for='fpt-product-2') Chọn sản phẩm:
              select#fpt-product-2.product-select
                option(value='', disabled, selected) -- Chọn sản phẩm --
                each item in productsFpt
                  option(value=item.id, data-id=item.id) #{item.name}

      .row.mt-4.mb-4
        .col-12.text-center
          button#compare-btn.compare-btn.fpt-compare-btn
            i.fas.fa-sync-alt.mr-2
            | So sánh ngay

        .col-md-6
          #result-1.product-info
            .no-product
              i.fas.fa-box-open.fa-3x.mb-3
              p Vui lòng chọn sản phẩm 1

        .col-md-6
          #result-2.product-info
            .no-product
              i.fas.fa-box-open.fa-3x.mb-3
              p Vui lòng chọn sản phẩm 2

    script(src='https://code.jquery.com/jquery-3.5.1.min.js')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js')
    script(src="/client/js/fptshop.js")